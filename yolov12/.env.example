# YOLOv12 FastAPI Configuration
# Copy file ini ke .env dan sesuaikan nilai-nilainya

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False
LOG_LEVEL=info

# Model Configuration
DEFAULT_MODEL=yolov12m.pt
DEFAULT_IMG_SIZE=640
DEFAULT_CONF_THRESHOLD=0.25

# Available Models (comma-separated)
AVAILABLE_MODELS=yolov12n.pt,yolov12s.pt,yolov12m.pt,yolov12l.pt,yolov12x.pt

# Model Cache
ENABLE_MODEL_CACHE=True
MAX_CACHED_MODELS=3

# CORS Configuration
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Performance
MAX_WORKERS=4
TIMEOUT=300

# GPU Configuration
USE_GPU=True
GPU_DEVICE=0

# Custom Model Paths (optional)
# CUSTOM_MODELS_PATH=/path/to/custom/models

# Logging
LOG_FORMAT=json
LOG_FILE=logs/api.log
