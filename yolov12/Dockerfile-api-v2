# Stage 1: Builder
FROM python:3.11-slim as builder

WORKDIR /app

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# Copy requirements
COPY requirements-api-v2.txt .

# Create wheels
RUN pip wheel --no-cache-dir --wheel-dir /app/wheels -r requirements-api-v2.txt

# Stage 2: Runtime
FROM python:3.11-slim

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    libsm6 \
    libxext6 \
    libxrender-dev \
    libgomp1 \
    libglib2.0-0 \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy wheels from builder
COPY --from=builder /app/wheels /app/wheels

# Install Python packages from wheels
RUN pip install --no-cache /app/wheels/*.whl && rm -rf /app/wheels

# Copy application code
COPY api_v2.py .
COPY client_v2.py .
COPY runs/ runs/

# Copy model if exists locally (optional)
# COPY yolov12_model.pt runs/detect/train4/weights/best.pt

# Create non-root user
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
USER appuser

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8000/v1/health || exit 1

# Expose port
EXPOSE 8000

# Run application
CMD ["python", "-m", "uvicorn", "api_v2:app", "--host", "0.0.0.0", "--port", "8000"]
